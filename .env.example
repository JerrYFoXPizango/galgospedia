# ============================================================
# GALGOSPEDIA — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_NAME="Galgospedia"
APP_URL=http://galgospedia.test
APP_ENV=local
APP_DEBUG=true
APP_SECRET=change_this_to_a_random_64_character_string_before_going_live

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=galgospedia
DB_USER=galgo_user
DB_PASS=dev_password_here

# Email (SMTP)
MAIL_HOST=smtp.banahosting.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USER=noreply@galgospedia.com
MAIL_PASS=your_email_password
MAIL_FROM_NAME="Galgospedia"

# Uploads
UPLOAD_MAX_SIZE=10485760
UPLOAD_DIR=uploads/dogs
