storage/
laragon/tmp/
*.log

# ── Sistema operativo ────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDEs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp

