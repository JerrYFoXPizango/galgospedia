# ── Entorno ──────────────────────────────────────────────────
.env
.env.local

# ── Dependencias ─────────────────────────────────────────────
vendor/
node_modules/

# ── Archivos subidos por usuarios (no van en git) ────────────
public/uploads/dogs/*.webp
public/uploads/dogs/*.jpg
public/uploads/dogs/*.png
public/uploads/avatars/*.webp
public/uploads/avatars/*.jpg
public/img/sponsors/*.png
public/img/sponsors/*.jpg
public/img/sponsors/*.webp
